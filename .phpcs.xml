<?xml version="1.0"?>
<ruleset name="TradePress">
	<description>TradePress PHPCS configuration. Standards: WordPress-Core, WordPress-Docs, WordPress-Extra.</description>

	<rule ref="WordPress-Core"/>
	<rule ref="WordPress-Docs"/>
	<rule ref="WordPress-Extra"/>

	<!--
		TradePress uses kebab-case.php file naming (e.g. strategy-handler.php, trading-tabs.php).
		The WordPress.Files.FileName sniff expects class files to be prefixed with "class-",
		which is not the convention used in this project. Suppressed project-wide.
	-->
	<rule ref="WordPress.Files.FileName">
		<severity>0</severity>
	</rule>
</ruleset>
